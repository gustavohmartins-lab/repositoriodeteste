  <step>
    <name>INPUT_ORDER_ID</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>CONN_HANA</connection>
    <sql>SELECT REPLACE(REPLACE(ORDER_ID, CHAR(10), ''), ' ', '') AS ORDER_ID FROM (
SELECT DISTINCT
	ORDER_ID
FROM
	U_PRJ_ECOM.ODS_VTEX_FEED_SSG_BR_SHOP
WHERE
	1 = 1
	AND "COMMIT" IS NULL
	AND ORDER_ID IS NOT NULL
UNION
-- get list items that were not loaded by feed
SELECT ORDER_ID FROM (
SELECT DISTINCT
	T2.ORDER_ID
	, T2.UPDATED_AT
FROM
	U_PRJ_ECOM.RAW_VTEX_SSG_BR_SHOP_SALES_ORDER_LIST T2
WHERE
	1=1
	AND T2.ORDER_ID NOT IN (SELECT DISTINCT T3.ORDER_ID FROM U_PRJ_ECOM.RAW_VTEX_SSG_BR_SHOP_SALES_ORDER T3)
ORDER BY
    T2.UPDATED_AT DESC
LIMIT 300
));</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
    <row-meta/>
    <attributes/>
    <cluster_schema/>
