    </entry>
    <entry>
      <name>INSERT</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <sql>DO
BEGIN

	INSERT INTO U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER (
	SELECT DISTINCT
		  ORDER_ID,
		   SEQUENCE,
		   MARKETPLACE_ORDER_ID,
		   MARKETPLACE_SERVICES_ENDPOINT,
		   SELLER_ORDER_ID,
		   ORIGIN,
		   AFFILIATE_ID,
		   SALES_CHANNEL,
		   MERCHANT_NAME,
		   STATUS,
		   STATUS_DESCRIPTION,
		   VALUE,
		   UTCTOLOCAL(LEFT(CREATION_DATE, 10), 'America/Sao_Paulo', 'platform') AS CREATION_DATE,
		   UTCTOLOCAL(REPLACE(LEFT(CREATION_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS CREATION_TIMESTAMP,
		   UTCTOLOCAL(REPLACE(LEFT(LAST_CHANGE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS LAST_CHANGE,
		   ORDER_GROUP,
		   TOTAL_ITEMS,
		   TOTAL_DISCOUNTS,
		   TOTAL_SHIPPING,
		   TOTAL_TAX,
		   CUSTOMER_ID,
		   IS_CORPORATE,
		   USER_PROFILE_ID,
		   CUSTOMER_CLASS,
		   GIFT_REGISTRY_DATA,
		   MARKETING_DATA_ID,
		   UTM_SOURCE,
		   UTM_PARTNER,
		   UTM_MEDIUM,
		   UTM_CAMPAIGN,
		   COUPON,
		   UTMI_CAMPAIGN,
		   UTMI_PAGE,
		   UTMI_PART,
		   MARKETING_TAGS,
		   SELLER_ID,
		   SELLER_NAME,
		   SELLER_LOGO,
		   FULFILLMENT_ENDPOINT,
		   CALL_CENTER_OPERATOR_DATA,
		   FOLLOW_UP_EMAIL,
		   LAST_MESSAGE,
		   HOSTNAME,
		   INVOICE_DATA,
		   CHANGES_ATTACHMENT,
		   OPEN_TEXT_FIELD,
		   ROUNDING_ERROR,
		   ORDER_FORM_ID,
		   COMMERCIAL_CONDITION_DATA,
		   IS_COMPLETED,
		   ALLOW_CANCELLATION,
		   ALLOW_EDITION,
		   IS_CHECKED_IN,
		   MARKETPLACE,
		   UTCTOLOCAL(REPLACE(LEFT(AUTHORIZED_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS AUTHORIZED_DATE,
		   UTCTOLOCAL(REPLACE(LEFT(INVOICED_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS INVOICED_DATE,
		   CANCEL_REASON,
		   SUBSCRIPTION_DATA,
		   TAX_DATA,
		   CHECKED_IN_PICKUP_POINT_ID,
		   CANCELLATION_REQUESTED_BY_USER,
		   CANCELLATION_REQUESTED_BY_SYSTEM,
		   CANCELLATION_REQUESTED_BY_SELLER_NOTIFICATION,
		   CANCELLATION_REQUESTED_BY_PAYMENT_NOTIFICATION,
		   CANCELLATION_REASON,
		   UTCTOLOCAL(REPLACE(LEFT(CANCELLATION_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS CANCELLATION_DATE,
		   CURRENT_TIMESTAMP AS CREATED_AT,
		   CURRENT_TIMESTAMP AS UPDATED_AT,
		   EMAIL_DOMAIN,
		   OBS,
           CD_STORE_INFORMATION,
           CD_VENDEDOR,
           CD_STORENAME,
           CUSTOM_DATA,
			TO_VARCHAR(PACKAGE_ATTACHMENT)

	  FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER tmp
	
	   WHERE 1=1
	   AND tmp.ORDER_ID IS NOT NULL
	   AND tmp.ORDER_ID NOT IN (SELECT DISTINCT ORDER_ID FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER so WHERE so.ORDER_ID = tmp.ORDER_ID))
	 -- LIMIT 10
	;

	COMMIT;

	INSERT INTO U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM (
SELECT
       X.ORDER_ID,
       X.UNIQUE_ID,
       X.SKU_ID,
       X.PRODUCT_ID,
       X.EAN,
       X.LOCK_ID,
       X.ITEM_ATTACHMENT,
       X.ATTACHMENTS,
       X.QUANTITY,
       X.SELLER,
       X.NAME,
       X.REF_ID,
       X.PRICE,
       X.LIST_PRICE,
       X.MANUAL_PRICE,
       X.PRICE_TAGS,
       X.IMAGE_URL,
       X.DETAIL_URL,
       X.BUNDLE_ITEMS,
       X.PARAMS,
       X.OFFERINGS,
       X.SELLER_SKU,
       X.PRICE_VALID_UNTIL,
       X.COMMISSION,
       X.TAX,
       X.PRE_SALE_DATE,
       X.BRAND_NAME,
       X.BRAND_ID,
       X.CATEGORIES_IDS,
       X.PRODUCT_CLUSTER_ID,
       X.COMMERCIAL_CONDITION_ID,
       X.OFFERING_INFO,
       X.OFFERING_TYPE,
       X.OFFERING_TYPE_ID,
       X.MEASUREMENT_UNIT,
       X.UNIT_MULTIPLIER,
       X.SELLING_PRICE,
       X.IS_GIFT,
       X.SHIPPING_PRICE,
       X.REWARD_VALUE,
       X.FREIGHT_COMMISSION,
       X.PRICE_DEFINITIONS,
       X.TAX_CODE,
       X.PARENT_ITEM_INDEX,
       X.PARENT_ASSEMBLY_BINDING,
       X.CALL_CENTER_OPERATOR,
       X.SERIAL_NUMBERS,
       X.ASSEMBLIES,
       X.COST_PRICE,
       X.MARKETPLACE_ITEMS,
       X.ITEM_INDEX,
       CURRENT_TIMESTAMP AS CREATED_AT,
       CURRENT_TIMESTAMP AS UPDATED_AT,
       X.CATEGORIES
FROM (
    SELECT
           tmp.*,
           ROW_NUMBER() OVER (
               PARTITION BY tmp.ORDER_ID, tmp.ITEM_INDEX
               ORDER BY tmp.ORDER_ID, tmp.ITEM_INDEX
           ) AS RN
    FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM tmp
    WHERE tmp.ORDER_ID IS NOT NULL
) X
WHERE X.RN = 1
  AND NOT EXISTS (
        SELECT 1
        FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM so
        WHERE so.ORDER_ID   = X.ORDER_ID
          AND so.ITEM_INDEX = X.ITEM_INDEX
  )
;


	COMMIT;

	INSERT INTO U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PAYMENT (
	SELECT
		   DISTINCT
		   ORDER_ID,
           TRANSACTION_ID,
           PAYMENT_ID,
           PAYMENT_SYSTEM,
           PAYMENT_SYSTEM_NAME,
           VALUE,
           INSTALLMENTS,
           REFERENCE_VALUE,
           CARD_HOLDER,
           CARD_NUMBER,
           FIRST_DIGITS,
           LAST_DIGITS,
           CVV2,
           EXPIRE_MONTH,
           EXPIRE_YEAR,
           URL,
           GIFT_CARD_ID,
           GIFT_CARD_NAME,
           GIFT_CARD_CAPTION,
           REDEMPTION_CODE,
           PAYMENT_GROUP,
           TID,
           DUE_DATE,
           RETURN_CODE,
           MESSAGE,
           AUTH_ID,
           NSU,
           ACQUIRER,
           GIFT_CARD_PROVIDER,
           GIFT_CARD_AS_DISCOUNT,
           KOIN_URL,
           ACCOUNT_ID,
           PARENT_ACCOUNT_ID,
           BANK_ISSUED_INVOICE_IDENTIFICATION_NUMBER,
           BANK_ISSUED_INVOICE_IDENTIFICATION_NUMBER_FORMATTED,
           BANK_ISSUED_INVOICE_BAR_CODE_NUMBER,
           BANK_ISSUED_INVOICE_BAR_CODE_TYPE,
           CURRENT_TIMESTAMP AS CREATED_AT,
           CURRENT_TIMESTAMP AS UPDATED_AT
	  FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PAYMENT tmp
	 WHERE 1=1
	   AND tmp.ORDER_ID IS NOT NULL
	   AND tmp.ORDER_ID NOT IN (SELECT DISTINCT ORDER_ID FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PAYMENT sop WHERE sop.ORDER_ID = tmp.ORDER_ID AND sop.TRANSACTION_ID = tmp.TRANSACTION_ID AND sop.PAYMENT_ID = tmp.PAYMENT_ID))
	 -- LIMIT 10
	;

	COMMIT;

	INSERT INTO U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_SHIPPING (
	SELECT DISTINCT
		ORDER_ID
		, SHIPPING_DATA_ID
		, ITEM_INDEX
		, SELECTED_SLA
		, LOCK_TTL
		, PRICE
		, LIST_PRICE
		, SELLING_PRICE
		, DELIVERY_WINDOW
		, DELIVERY_COMPANY
		, SHIPPING_ESTIMATE
		, UTCTOLOCAL(REPLACE(LEFT(SHIPPING_ESTIMATE_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS SHIPPING_ESTIMATE_DATE, SLAS
		, SHIPS_TO
		, COURIER_ID
		, COURIER_NAME
		, DOCK_ID
		, QUANTITY
		, WAREHOUSE_ID
		, ACCOUNT_CARRIER_NAME
		, DELIVERY_CHANNEL
		, PICKUP_STORE_INFO
		, ADDRESS_ID
		, POLYGON_NAME
		, PICKUP_POINT_ID
		, TRANSIT_TIME
		, TRACKING_HINTS
		, CURRENT_TIMESTAMP AS CREATED_AT
		, CURRENT_TIMESTAMP AS UPDATED_AT
		, COUNTRY
		, "STATE"
		, CITY
		, POSTAL_CODE
	FROM
	    U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_SHIPPING tmp
	WHERE 1=1
		AND tmp.ORDER_ID IS NOT NULL
		AND tmp.ORDER_ID NOT IN (SELECT DISTINCT ORDER_ID FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_SHIPPING sos WHERE sos.ORDER_ID = tmp.ORDER_ID AND sos.ITEM_INDEX = tmp.ITEM_INDEX))
	;

	COMMIT;

	INSERT INTO U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM_COMPONENTS (
SELECT
       X.ORDER_ID,
       X.UNIQUE_ID,
       X.SKU_ID,
       X.UNIQUE_ID_COMPONENT,
       X.SKU_ID_COMPONENT,
       X.PRODUCT_ID,
       X.EAN,
       X.LOCK_ID,
       X.ITEM_ATTACHMENT_CONTENT,
       X.ITEM_ATTACHMENT_NAME,
       X.ATTACHMENTS,
       X.QUANTITY,
       X.SELLER,
       X.NAME,
       X.REF_ID,
       X.PRICE,
       X.LIST_PRICE,
       X.MANUAL_PRICE,
       X.PRICE_TAGS,
       X.IMAGE_URL,
       X.DETAIL_URL,
       X.BUNDLE_ITEMS,
       X.PARAMS,
       X.OFFERINGS,
       X.SELLER_SKU,
       X.PRICE_VALID_UNIT,
       X.COMISSION,
       X.TAX,
       X.PRE_SALE_DATE,
       X.BRAND_NAME,
       X.BRAND_ID,
       X.CATEGORIES_ID,
       X.CATEGORIES,
       X.PRODUCT_CLUSTER_ID,
       X.COMMERCIAL_CONDITION_ID,
       X.CUBIC_WEIGHT,
       X.HEIGHT,
       X.LENGTH,
       X.WEIGHT,
       X.WIDTH,
       X.OFFERING_INFO,
       X.OFFERING_TYPE,
       X.OFFERING_TYPE_ID,
       X.MEASUREMENT_UNIT,
       X.UNIT_MULTIPLIER,
       X.SELLING_PRICE,
       X.IS_GIFT,
       X.SHIPPING_PRICE,
       X.REWARD_VALUE,
       X.FREIGHT_COMISSION,
       X.PRICE_DEFINITIONS,
       X.TAX_CODE,
       X.PARENT_ITEM_INDEX,
       X.PARENT_ASSEMBLY_BINDING,
       X.CALL_CENTER_OPERATOR,
       X.SERIAL_NUMBERS,
       X.ASSEMBLIES,
       X.COST_PRICE,
       CURRENT_TIMESTAMP AS CREATED_AT,
       CURRENT_TIMESTAMP AS UPDATED_AT
FROM (
    SELECT
           tmp.*,
           ROW_NUMBER() OVER (
               PARTITION BY tmp.ORDER_ID, tmp.UNIQUE_ID_COMPONENT, tmp.PRICE
               ORDER BY tmp.ORDER_ID, tmp.UNIQUE_ID_COMPONENT, tmp.PRICE
           ) AS RN
    FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM_COMPONENTS tmp
    WHERE tmp.ORDER_ID IS NOT NULL
) X
WHERE X.RN = 1
  AND NOT EXISTS (
        SELECT 1
        FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM_COMPONENTS soj
        WHERE soj.ORDER_ID            = X.ORDER_ID
          AND soj.UNIQUE_ID_COMPONENT = X.UNIQUE_ID_COMPONENT
          AND soj.PRICE              = X.PRICE
  )
;


	COMMIT;


	INSERT INTO U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PACKAGE (
	SELECT
	 ORDER_ID
	,ITEM_INDEX
	,UTCTOLOCAL(REPLACE(LEFT(ISSUANCE_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform') AS ISSUANCE_DATE
    
	, CASE
	     	WHEN tmp.DELIVERED_DATE = '0001-01-01T00:00:00.0000000+00:00' THEN NULL
	     	ELSE UTCTOLOCAL(REPLACE(LEFT(DELIVERED_DATE, 19), 'T', ' '), 'America/Sao_Paulo', 'platform')
	END AS DELIVERED_DATE

    ,INVOICE_NUMBER
	,TRACKING_NUMBER
	,INVOICE_KEY
	,TRACKING_URL
	,EMBEDDED_INVOICE
	,TYPE
	,CFOP
	,RESTITUTIONS
	,VOLUMES
	,QUANTITY
	,PRICE
	,DESCRIPTION
	,UNIT_MULTIPLIER
	,STATUS
	,FINISHED
	,CURRENT_TIMESTAMP AS CREATED_AT
    ,CURRENT_TIMESTAMP AS UPDATED_AT
	  FROM  U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PACKAGE tmp
	 WHERE 1=1
	   AND tmp.ORDER_ID IS NOT NULL
	   AND tmp.ITEM_INDEX IS NOT NULL
	   AND tmp.ORDER_ID NOT IN (SELECT DISTINCT ORDER_ID FROM  U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PACKAGE sog WHERE sog.ORDER_ID = tmp.ORDER_ID AND sog.ITEM_INDEX = tmp.ITEM_INDEX))
	 -- LIMIT 10
	;

	COMMIT;

	INSERT INTO U_PRJ_ECOM.ODS_VTEX_${TABLE_ACCOUNT_NAME}_RATES_AND_BENEFITS_DATA
	SELECT * FROM U_PRJ_ECOM.TMP_VTEX_${TABLE_ACCOUNT_NAME}_RATES_AND_BENEFITS_DATA;
	COMMIT;


END;</sql>
      <useVariableSubstitution>T</useVariableSubstitution>
