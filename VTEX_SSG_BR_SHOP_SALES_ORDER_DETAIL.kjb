      <draw>Y</draw>
      <nr>0</nr>
      <xloc>1024</xloc>
      <yloc>96</yloc>
      <attributes_kjc/>
    </entry>
    <entry>
      <name>COMMIT</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <sql>UPDATE U_PRJ_ECOM.ODS_VTEX_FEED_${TABLE_ACCOUNT_NAME} T1
SET	T1."COMMIT" = 'Y'
WHERE
	T1.ORDER_ID IN (
		SELECT DISTINCT
			T2.ORDER_ID
		FROM
			U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2
	)</sql>
