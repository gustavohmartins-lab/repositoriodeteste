    <entry>
      <name>DELETE</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <sql>DELETE FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);

DELETE FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);

DELETE FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_ITEM_COMPONENTS T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);

DELETE FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PACKAGE T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);

DELETE FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_PAYMENT T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);

DELETE FROM U_PRJ_ECOM.RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER_SHIPPING T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);

DELETE FROM U_PRJ_ECOM.ODS_VTEX_${TABLE_ACCOUNT_NAME}_RATES_AND_BENEFITS_DATA T1
WHERE T1.ORDER_ID IN (SELECT DISTINCT T2.ORDER_ID FROM U_PRJ_ECOM.TMP_RAW_VTEX_${TABLE_ACCOUNT_NAME}_SALES_ORDER T2);
</sql>
      <useVariableSubstitution>T</useVariableSubstitution>
      <sqlfromfile>F</sqlfromfile>
      <sqlfilename/>
      <sendOneStatement>F</sendOneStatement>
      <connection>CONN_HANA</connection>
